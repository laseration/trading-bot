{
  "name": "trading-bot",
  "private": true,
  "scripts": {
    "start": "node src/index.js",
    "start:demo": "set \"TRADING_ENV=demo\" && node src/index.js",
    "start:live": "set \"TRADING_ENV=live\" && node src/index.js",
    "start:demo-pulse": "set \"TRADING_ENV=demo\" && node src/demoPulse.js",
    "test:mt5-demo-trade": "set \"TRADING_ENV=demo\" && node src/demoMt5TestTrade.js",
    "test": "node --test",
    "test:unit": "node --test",
    "audit:candidates": "node src/diagnostics/runCandidateAudit.js",
    "audit:backtest": "node src/diagnostics/runBacktestAudit.js",
    "check": "node -e \"require('./src/config'); require('./src/strategy'); require('./src/hybridDecision'); require('./src/bot'); require('./src/risk'); console.log('ok')\"",
    "check:startup": "set \"TRADING_ENV=demo\" && node scripts/checkStartupState.js",
    "analyze:trades": "node src/analyzeTradeHistory.js",
    "analyze:eurusd-bias": "node src/analyzeEurUsdBiasDiagnostics.js",
    "backtest": "node src/backtest.js",
    "backtest:compare": "node src/compareStrategies.js",
    "backtest:sweep": "node src/parameterSweep.js",
    "backtest:attribution": "node src/performanceAttributionReport.js",
    "backtest:walkforward": "node src/walkForwardAnalysis.js",
    "backtest:news": "node src/backtestNews.js",
    "backfill:signals": "node src/backfillSignalResults.js",
    "reconcile-results": "node src/reconcileResults.js",
    "weekly-summary": "node src/postWeeklySummary.js",
    "bridge:demo": "set \"TRADING_ENV=demo\" && .venv\\Scripts\\python.exe bridge\\mt5_bridge.py",
    "bridge:live": "set \"TRADING_ENV=live\" && .venv\\Scripts\\python.exe bridge\\mt5_bridge.py",
    "forwarder:demo": "set \"TRADING_ENV=demo\" && .venv\\Scripts\\python.exe bridge\\telegram_forwarder.py",
    "forwarder:live": "set \"TRADING_ENV=live\" && .venv\\Scripts\\python.exe bridge\\telegram_forwarder.py"
  },
  "dependencies": {
    "axios": "^1.15.0",
    "natural": "^8.1.1",
    "sharp": "^0.34.5"
  }
}
